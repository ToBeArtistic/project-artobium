<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - artobium</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/artobium.styles.css" asp-append-version="true" />
</head>
<body>

<div class="d-flex flex-column dither" style="height:100vh; overflow:hidden;">

    <!-- Top navbar -->
    <nav class="d-flex justify-content-end navbar navbar-expand-lg pe-5">
        <ul class="nav nav-pills">
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Index">
                <button class="btn glass-theme-2 glass-fill">Home</button>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Index">
                <button class="btn glass-theme-2 glass-fill">Info</button>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Index">
                <button class="btn glass-theme-2 glass-fill">Development</button>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Index">
                <button class="btn glass-theme-2 glass-fill">Art & Design</button>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Index">
                <button class="btn glass-theme-2 glass-fill">More</button>
                </a>
            </li>
        </ul>
    </nav>

    <div class="d-flex flex-grow-1 flex-shrink-1 flex-column p-1" style="min-height: 0; overflow-y: auto;">
            @RenderBody()
    </div>
</div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

