@page
@model InfoPageModel
@{
    ViewData["Title"] = "About me";
}

<!--name and subtitle box-->
<div class="m-4 d-flex flex-column justify-content-end" style="grid-column: 3 / 11; grid-row: 2 / 3;z-index:-20;">
    <h1 class="text-uppercase ps-4">Hello, I'm Tobias</h1>
    <hr class="color-highlight" />
    <span class="ps-5"></span>
</div>

<div class="d-flex m-5 justify-content-start align-items-top flex-grow-1 flex-row flex-column position-absolute top-0 start-0 rounded-circle"
     style="object-fit: cover; z-index:-10;">
    <div class="position-relative" style="width:15rem; height:15rem; overflow-hidden;">
        <div class="position-absolute secondary-fill top-0 start-0" style="height: 2rem; width: 2rem;z-index:-1;"></div>
        <div class="rounded-circle w-100 h-100 position-relative" style="overflow: hidden;">
            <img src="~/images/tobias-grayscale.png" class="position-absolute"
                 style="width: auto; height:100%; left: -1rem;" />
        </div>
        <div class="position-absolute secondary-fill end-0 bottom-0" style="height: 2rem; width: 2rem;z-index:-1;">
        </div>
    </div>
</div>

<div class="scroll-x d-flex position-relative" style="grid-column: 1 / 10; grid-row: 3 / 10;">
    <div class="d-flex justify-content-center align-items-center flex-grow-1 flex-row flex-column m-5 mx-2 position-relative"
         style="overflow:hidden;min-width:30rem;">
        <div class="linear-gradient-fill border-start border-text d-flex justify-content-center align-items-center position-absolute p-4 ps-5"
             style="width: 100%; height:100%;z-index:2;">
            <span class="text-large text-shadow text-start">
                <p>I have been <span class="color-highlight">coding</span> for more than 13 years, and <span
                    class="color-highlight">drawing</span> since before I could talk.
                    I enjoy <span class="color-highlight">creating</span> things and <span
                        class="color-highlight">integrating</span> new ideas.</p>
                    </span>
                </div>
            </div>
            <div class="d-flex position-relative" style="height:100%; min-width: 15rem; max-width: 15rem;">
                <div class="position-absolute secondary-fill top-0 start-0" style="height: 2rem; width: 2rem;z-index:-1;"></div>
                <div class="d-flex flex-column m-2 p-4 glass-theme glass-fill">
                    <h4 class="">technical foundation</h4>
                    <hr />
                    <span>I apply <span class="color-highlight">clean coding</span> principles, and I am used to working with <span class="color-highlight">dockerized solutions</span> with <span class="color-highlight">continous integration</span> and <span class="color-highlight">deployment</span> pipelines.</span>
                </div>
                <div class="position-absolute secondary-fill end-0 bottom-0" style="height: 2rem; width: 2rem;z-index:-1;">
                </div>
            </div>
            <div class="d-flex position-relative" style="height:100%; min-width: 15rem; max-width: 15rem;">
                <div class="position-absolute secondary-fill top-0 start-0" style="height: 2rem; width: 2rem;z-index:-1;"></div>
                <div class="d-flex flex-column m-2 p-4 glass-theme glass-fill">
                    <h4 class="">data management</h4>
                    <hr />
                    <span>I work well with <span class="color-highlight">databases and sql</span>, and I have experience with setting up various types of <span class="color-highlight">data integrations</span>.</span>
                </div>
                <div class="position-absolute secondary-fill end-0 bottom-0" style="height: 2rem; width: 2rem;z-index:-1;">
                </div>
            </div>
            <div class="d-flex position-relative" style="height:100%; min-width: 15rem;  max-width: 15rem;">
                <div class="position-absolute secondary-fill top-0 start-0" style="height: 2rem; width: 2rem;z-index:-1;"></div>
                <div class="d-flex flex-column m-2 p-4 glass-theme glass-fill">
                    <h4 class="">visual presentation</h4>
                    <hr />
                    <span>I leverage my <span class="color-highlight">artistic background</span> to <span class="color-highlight">present information</span> in appealing ways.</span>
                </div>
                <div class="position-absolute secondary-fill end-0 bottom-0" style="height: 2rem; width: 2rem;z-index:-1;">
                </div>
            </div>
            <div class="d-flex position-relative" style="height:100%; min-width: 15rem; max-width: 15rem;">
                <div class="position-absolute secondary-fill top-0 start-0" style="height: 2rem; width: 2rem;z-index:-1;"></div>
                <div class="d-flex flex-column m-2 p-4 glass-theme glass-fill">
                    <h4 class="">user experience</h4>
                    <hr />
                    <span>I keep in mind <span class="color-highlight">the user's journey</span>, as they interact with solutions I work on. And have used <span class="color-highlight">analytics</span> software to aid in this.</span>
                </div>
                <div class="position-absolute secondary-fill end-0 bottom-0" style="height: 2rem; width: 2rem;z-index:-1;">
                </div>
            </div>
        </div>