@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}


    <section class="index-grid p-0 m-0">
        
        <!--name and subtitle box-->
        <div class="m-4" style="grid-column: 5 / 11; grid-row: 2 / 3">
            <h1 class="text-uppercase pl-3">Tobias A. Højsgaard</h1>
            <hr class="color-highlight"/>
            <h4 class="pl-3">Software engineer // Artist</h4>
        </div>
        <div class="png-overlay-highlight" style="grid-column: 9 / span 1; grid-row: 2 / 3;z-index:1;">
            <img src="~/images/logo.png" class="img-fluid"/>
        </div>

        <button class="btn glass-theme glass-fill rounded m-5" style="grid-column: 2 / span 2; grid-row: 2 / span 5;"></button>
        <button class="btn glass-theme glass-fill rounded m-5 png-overlay-primary" style="grid-column: 3 / span 2; grid-row: 5 / span 5;">
            <img src="~/images/plAnt.png" class="img-fluid img-fill-gridbox"/>
        </button>
        <button class="btn glass-theme glass-fill rounded m-5" style="grid-column: 2 / span 2; grid-row: 8 / span 4;"></button>

        <button class="btn glass-theme-2 glass-fill rounded d-flex p-3 pe-5 align-items-center justify-content-start me-5" style="grid-column: 3 / span 2; grid-row: 4 / span 1;">
            <span class="align-middle"><h5>Software Development</h5></span>
        </button>
        <button class="btn glass-theme-2 glass-fill rounded d-flex p-3 pe-5 align-items-center justify-content-end me-5" style="grid-column: 2 / span 2; grid-row: 7 / span 1;">
            <span class="align-middle"><h5>Art & Design</h5></span>
        </button>
        <button class="btn glass-theme-2 glass-fill rounded d-flex p-3 pe-5 align-items-center justify-content-center" style="grid-column: 3 / span 1; grid-row: 10 / span 1;">
            <span class="align-middle"><h5>And more!</h5></span>
        </button>
        <!--about me - textbox-->
        <div class="border-start border-end p-5" style="grid-column: 5 / 10; grid-row: 4 / 8;">
            <span class="text-large">"Hello, I am a <span class="color-highlight">full-stack developer</span> with a <span class="color-highlight">creative</span> spark. I seek to bring novel experiences to life."</span>
            <button class="btn btn-primary m-4 p-3"><h5>Learn more</h5></button>
        </div>
        <!--little hatch-->
        <div class="hatch-subtle" style="grid-column: 10 / span 2; grid-row: 4 / 8;">
        </div>
        <!--email img-->
        <div class="png-overlay-primary" style="grid-column: 9 / 10; grid-row: 10/11">
            <img src="~/images/letter.png" class="img-fill-gridbox"/>
        </div>
        <!--email text-->
        <div class="d-flex ms-5 pt-2 pb-2 align-items-center justify-content-end" style="grid-column: 6 / 9; grid-row: 10/11">
            <span class="align-middle">hoejsgaard.tobias@gmail.com</span>
        </div>
        <!--phone img-->
        <div class="png-overlay-primary" style="grid-column: 9 / 10; grid-row: 11/12">
            <img src="~/images/phone.png" class="img-fill-gridbox"/>
        </div>
        <!--phone text-->
        <div class="d-flex ms-5 pt-2 pb-2 align-items-center justify-content-end" style="grid-column: 6 / 9; grid-row: 11/12"> 
            <span class="align-middle">+45  29 26 84 13</span>
        </div>
    </div>


