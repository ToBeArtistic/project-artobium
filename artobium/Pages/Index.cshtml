@page
@model IndexModel
@{
    ViewData["Title"] = "Tobias - Developer // Artist";
}
@inject IndexModel.Localizer Loc

<div id="overlay" class="" style="display:none; position:fixed; inset:0; z-index:1000;">
    <div id="overlay-content" class="overlay-1 position-absolute top-50 start-50 translate-middle">
        <!-- partial loads here -->
    </div>
</div>

<script>
    async function openOverlay(handler, data = {}) {
        const params = new URLSearchParams({ handler, ...data });
        const response = await fetch(`?${params}`);
        document.getElementById('overlay-content').innerHTML = await response.text();
        const overlay = document.getElementById('overlay');
        overlay.style.display = 'block';
        requestAnimationFrame(() => overlay.classList.add('visible'));
    }

    function closeOverlay() {
        const overlay = document.getElementById('overlay');
        overlay.classList.remove('visible');
        setTimeout(() => {
            overlay.style.display = 'none';
            document.getElementById('overlay-content').innerHTML = '';
        }, 300); // match transition duration
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeOverlay();
    });
</script>

